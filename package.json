    "pinia": "latest",
    "vue": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "latest",
    "concurrently": "latest",
    "electron": "28.3.3",
    "vite": "latest",
    "wait-on": "latest"
  }
}